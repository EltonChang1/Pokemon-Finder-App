# Environment Variables for Pokemon-Finder-App Server

NODE_ENV=production
PORT=8080

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>
MONGO_URI=your_mongodb_connection_string_here

# Optional: forwarded to Nominatim as User-Agent (include contact or repo URL)
# NOMINATIM_USER_AGENT=PokeFindHQ/1.2 (https://github.com/EltonChang1/Pokemon-Finder-App)
