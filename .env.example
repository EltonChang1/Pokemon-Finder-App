# MongoDB
MONGO_URI=mongodb://localhost:27017/pokefind

# API server (matches client `package.json` proxy default)
PORT=8080
NODE_ENV=development

# Identifying string for Nominatim (recommended in production)
# NOMINATIM_USER_AGENT=PokeFindHQ/1.0 (your-site.example; contact@example.com)

# Client: leave empty in dev to use the CRA proxy to the same host/port as `npm start` for /api
# Set to your deployed API origin for production builds.
REACT_APP_API_URL=
